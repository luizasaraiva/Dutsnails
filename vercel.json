{
  "version": 2,
  "builds": [
    {
      "src": "api/*.js",
      "use": "@vercel/node"
    },
    {
      "src": "*.html",
      "use": "@vercel/static"
    },
    {
      "src": "*.js",
      "use": "@vercel/static"
    },
    {
      "src": "*.css",
      "use": "@vercel/static"
    },
    {
      "src": "*.png",
      "use": "@vercel/static"
    },
    {
      "src": "*.webmanifest",
      "use": "@vercel/static"
    },
    {
      "src": "*.txt",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/api/meta-webhook/?",
      "dest": "/api/meta-webhook.js"
    },
    {
      "src": "/api/create-mercadopago-checkout/?",
      "dest": "/api/create-mercadopago-checkout.js"
    },
    {
      "src": "/api/mercadopago-webhook/?",
      "dest": "/api/mercadopago-webhook.js"
    },
    {
      "src": "/api/payment-status/?",
      "dest": "/api/payment-status.js"
    },
    {
      "src": "/api/available-slots/?",
      "dest": "/api/available-slots.js"
    },
    {
      "src": "/api/appointment-action-notify/?",
      "dest": "/api/appointment-action-notify.js"
    },
    {
      "src": "/api/send-reminders/?",
      "dest": "/api/send-reminders.js"
    },
    {
      "handle": "filesystem"
    }
  ],
  "crons": [
    {
      "path": "/api/send-reminders",
      "schedule": "0 * * * *"
    }
  ]
}
